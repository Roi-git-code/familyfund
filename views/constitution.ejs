            art5_intro: { en: "This article defines the emergencies for which a member may receive financial assistance without repayment obligations, the amounts, and processing timelines.", sw: "Kifungu hiki kinafafanua dharura ambazo mwanachama anaweza kupokea usaidizi wa kifedha bila wajibu wa kulipa, kiasi, na muda wa usindikaji." },
            art5_1_title: { en: "5.1 Eligible Emergencies", sw: "5.1 Dharura Zinazostahiki" },
            art5_1_text: { en: "<li><strong>Serious Disease/Hospitalization:</strong> Medical condition requiring inpatient treatment or major surgery, confirmed by a medical certificate from a recognized health facility.</li><li><strong>Accident:</strong> Physical injury resulting from unforeseen events (road traffic accident, fall, fire, etc.) requiring medical attention; excludes self-inflicted harm or injuries from criminal activity.</li><li><strong>Funeral Costs:</strong> Death of a member, spouse, child, or parent of a member. Assistance covers burial expenses.</li><li><strong>Natural Disaster:</strong> Loss or damage to member's primary residence due to flood, fire, earthquake, or other natural calamities, verified by local authorities.</li>", sw: "<li><strong>Ugonjwa Mbaya/Kulazwa:</strong> Hali ya kiafya inayohitaji matibabu ya kulazwa au upasuaji mkubwa, iliyothibitishwa na cheti cha daktari kutoka kituo cha afya kinachotambulika.</li><li><strong>Ajali:</strong> Jeraha la kimwili linalotokana na matukio yasiyotarajiwa (ajali ya barabarani, kuanguka, moto, n.k.) inayohitaji matibabu; haijumuishi majeraha ya kujitakia au yatokanayo na uhalifu.</li><li><strong>Gharama za Mazishi:</strong> Kifo cha mwanachama, mwenzi, mtoto, au mzazi wa mwanachama. Usaidizi unajumuisha gharama za mazishi.</li><li><strong>Maafa ya Asili:</strong> Hasara au uharibifu wa makao makuu ya mwanachama kutokana na mafuriko, moto, tetemeko la ardhi, au majanga mengine ya asili, yaliyothibitishwa na mamlaka za mitaa.</li>" },
            art5_2_title: { en: "5.2 Assistance Amounts and Limits", sw: "5.2 Kiasi na Mipaka ya Usaidizi" },
            art5_2_note: { en: "The following caps apply per incident (subject to available fund balance):", sw: "Vikomo vifuatavyo vinatumika kwa kila tukio (kutegemea salio la mfuko):" },
            emergencyType: { en: "Emergency Type", sw: "Aina ya Dharura" },
            maxAmount: { en: "Maximum Assistance", sw: "Usaidizi wa Juu Zaidi" },
            notes: { en: "Notes", sw: "Maelezo" },
            emergency1: { en: "Serious Disease/Hospitalization", sw: "Ugonjwa Mbaya/Kulazwa" },
            emergency1_note: { en: "Per member per year; requires medical verification", sw: "Kwa kila mwanachama kwa mwaka; inahitaji uthibitisho wa kimatibabu" },
            emergency2: { en: "Accident", sw: "Ajali" },
            emergency2_note: { en: "Per incident; requires police or medical report", sw: "Kwa kila tukio; inahitaji ripoti ya polisi au matibabu" },
            emergency3: { en: "Funeral Costs", sw: "Gharama za Mazishi" },
            emergency3_note: { en: "Per deceased; priority to immediate family of deceased member", sw: "Kwa kila marehemu; kipaumbele kwa familia ya karibu ya mwanachama aliyefariki" },
            emergency4: { en: "Natural Disaster", sw: "Maafa ya Asili" },
            emergency4_note: { en: "Per event; requires official confirmation", sw: "Kwa kila tukio; inahitaji uthibitisho rasmi" },
            amountNote: { en: "* Amounts may be adjusted by a two-thirds member vote based on fund growth.", sw: "* Kiasi kinaweza kubadilishwa kwa kura ya theluthi mbili ya wanachama kulingana na ukuaji wa mfuko." },
            art5_3_title: { en: "5.3 Processing Timeline", sw: "5.3 Muda wa Usindikaji" },
            art5_3_text: { en: "Once a request is submitted with all required documentation, the management team must decide and disburse within <strong>48 hours</strong> for urgent cases, or <strong>7 days</strong> for non-urgent.", sw: "Ombi likiwasilishwa pamoja na nyaraka zote zinazohitajika, timu ya usimamizi lazima iamue na itoe fedha ndani ya <strong>saa 48</strong> kwa kesi za dharura, au <strong>siku 7</strong> kwa zisizo za dharura." },
            art5_4_title: { en: "5.4 Documentation and Verification", sw: "5.4 Nyaraka na Uthibitishaji" },
            art5_4_text: { en: "All requests must be accompanied by evidence (medical certificate, police report, death certificate, etc.) and must be witnessed by at least one other member. False claims will lead to immediate termination of membership and recovery of funds.", sw: "Maombi yote lazima yaambatane na ushahidi (cheti cha matibabu, ripoti ya polisi, cheti cha kifo, n.k.) na lazima yashuhudiwe na angalau mwanachama mwingine mmoja. Madai ya uwongo yatasababisha kukatishwa kwa uanachama mara moja na kurudishwa kwa fedha." },
            // Article 6 – updated rates
            art6Badge: { en: "Article 6", sw: "Kifungu cha 6" },
            art6Title: { en: "Loan Policies", sw: "Sera za Mikopo" },
            art6_intro: { en: "This article establishes the framework for loans, distinguishing between service loans and investment loans, with specific terms, annual interest rates (reducing balance), eligibility, and application processes.", sw: "Kifungu hiki kinaanzisha mfumo wa mikopo, ukibainisha tofauti kati ya mikopo ya huduma na mikopo ya uwekezaji, pamoja na masharti maalum, viwango vya riba vya mwaka (salio linalopungua), sifa, na taratibu za maombi." },
            art6_1_title: { en: "6.1 Loan Categories", sw: "6.1 Aina za Mikopo" },
            art6_1_text: { en: "<li><strong>Service Loans:</strong> For personal needs such as education fees, medical expenses (not covered under free assistance), home repairs, or other essential services. Must be supported by evidence.</li><li><strong>Investment Loans:</strong> For business or income-generating projects. Requires submission of a project proposal and business plan.</li>", sw: "<li><strong>Mikopo ya Huduma:</strong> Kwa mahitaji ya kibinafsi kama ada za elimu, gharama za matibabu (zisizojumuishwa katika usaidizi wa bure), ukarabati wa nyumba, au huduma nyingine muhimu. Lazima iungwe mkono na ushahidi.</li><li><strong>Mikopo ya Uwekezaji:</strong> Kwa biashara au miradi inayozalisha mapato. Inahitaji uwasilishaji wa pendekezo la mradi na mpango wa biashara.</li>" },
            art6_2_title: { en: "6.2 Interest Rates and Terms", sw: "6.2 Viwango vya Riba na Masharti" },
            loanType: { en: "Loan Type", sw: "Aina ya Mkopo" },
            interestRate: { en: "Annual Interest Rate (Reducing Balance)", sw: "Kiwango cha Riba cha Mwaka (Salio Linalopungua)" },
            maxAmount: { en: "Maximum Amount", sw: "Kiasi cha Juu Zaidi" },
            repaymentPeriod: { en: "Repayment Period", sw: "Muda wa Malipo" },
            serviceLoan: { en: "Service Loan", sw: "Mkopo wa Huduma" },
            serviceRate: { en: "12%", sw: "12%" },
            servicePeriod: { en: "Up to 12 months", sw: "Hadi miezi 12" },
            investmentLoan: { en: "Investment Loan", sw: "Mkopo wa Uwekezaji" },
            investmentRate: { en: "13%", sw: "13%" },
            investmentPeriod: { en: "Up to 24 months", sw: "Hadi miezi 24" },
            rateNote: { en: "* Interest rates may be reviewed annually.", sw: "* Viwango vya riba vinaweza kukaguliwa kila mwaka." },
            art6_3_title: { en: "6.3 Eligibility and Application", sw: "6.3 Sifa na Maombi" },
            art6_3_text: { en: "<li>Must be a member in good standing for at least 6 months.</li><li>No outstanding loan or default in the previous 12 months.</li><li>Service loans require a witness (another member) to verify the purpose.</li><li>Investment loans require a detailed project proposal and at least two witnesses.</li><li>Applications are submitted through the FamilyFund Management System.</li>", sw: "<li>Lazima uwe mwanachama aliye katika hali nzuri kwa angalau miezi 6.</li><li>Hakuna mkopo uliobaki au kukosa kulipa katika miezi 12 iliyopita.</li><li>Mikopo ya huduma inahitaji shahidi (mwanachama mwingine) kuthibitisha madhumuni.</li><li>Mikopo ya uwekezaji inahitaji pendekezo la mradi la kina na angalau mashahidi wawili.</li><li>Maombi yanawasilishwa kupitia Mfumo wa Usimamizi wa FamilyFund.</li>" },
            art6_4_title: { en: "6.4 Project Proposal Analysis", sw: "6.4 Uchambuzi wa Pendekezo la Mradi" },
            art6_4_text: { en: "For investment loans, the management team will critically analyze the proposal for viability, expected returns, and risk. Approval requires a majority vote of the management. The applicant may be invited to present the proposal in a meeting.", sw: "Kwa mikopo ya uwekezaji, timu ya usimamizi itachambua kwa makini pendekezo kwa uwezekano, mapato yanayotarajiwa, na hatari. Idhini inahitaji kura nyingi za usimamizi. Mwombaji anaweza kualikwa kuwasilisha pendekezo katika mkutano." },
            art6_5_title: { en: "6.5 Processing Time", sw: "6.5 Muda wa Usindikaji" },
            art6_5_text: { en: "Service loan decisions within 48 hours of complete submission; investment loans within 7 days.", sw: "Maamuzi ya mkopo wa huduma ndani ya saa 48 tangu uwasilishaji kamili; mikopo ya uwekezaji ndani ya siku 7." },
            art6_6_title: { en: "6.6 Repayment and Default", sw: "6.6 Malipo na Kukosa Kulipa" },
            art6_6_text: { en: "<li>Repayments are made via the system, with automatic deductions from contributions or bank transfer.</li><li>Late payment penalty: 5% of monthly installment after 7 days grace period.</li><li>Default for more than 3 months leads to membership suspension and referral to the management for recovery action.</li>", sw: "<li>Malipo yanafanywa kupitia mfumo, kwa kukatwa kiotomatiki kutoka kwa michango au uhamisho wa benki.</li><li>Adhabu ya malipo ya kuchelewa: 5% ya kiasi cha kila mwezi baada ya muda wa mapumziko ya siku 7.</li><li>Kukosa kulipa kwa zaidi ya miezi 3 kunasababisha kusimamishwa kwa uanachama na kurejeshwa kwa usimamizi kwa hatua za kurejesha.</li>" },
            art6_7_title: { en: "6.7 Fairness and Anti‑favoritism", sw: "6.7 Usawa na Kupinga Upendeleo" },
            art6_7_text: { en: "All loan applications are reviewed using a standardized scoring matrix that considers member contribution history, reason, and risk. No management member may influence the decision for their own benefit or for a relative.", sw: "Maombi yote ya mkopo yanakaguliwa kwa kutumia matrix sanifu ya alama inayozingatia historia ya michango ya mwanachama, sababu, na hatari. Hakuna mwanachama wa usimamizi anayeruhusiwa kushawishi uamuzi kwa faida yake mwenyewe au ya jamaa." },
            // Article 7
            art7Badge: { en: "Article 7", sw: "Kifungu cha 7" },
            art7Title: { en: "Meetings and Communication", sw: "Mikutano na Mawasiliano" },
            art7_1_title: { en: "7.1 Annual General Meeting (AGM)", sw: "7.1 Mkutano Mkuu wa Mwaka (AGM)" },
            art7_1_text: { en: "An AGM shall be held every December to review financial performance, approve reports, and discuss amendments. Notice must be given 14 days in advance.", sw: "Mkutano Mkuu wa Mwaka utafanyika kila Desemba kukagua utendaji wa kifedha, kuidhinisha ripoti, na kujadili marekebisho. Taarifa lazima itolewe siku 14 kabla." },
            art7_2_title: { en: "7.2 Special Meetings", sw: "7.2 Mikutano Maalum" },
            art7_2_text: { en: "Extraordinary meetings may be called by the management or by petition of at least 1/3 of members. Decisions require a simple majority unless stated otherwise.", sw: "Mikutano ya dharura inaweza kuitishwa na usimamizi au kwa ombi la angalau 1/3 ya wanachama. Maamuzi yanahitaji kura nyingi tu isipokuwa imeelezwa vinginevyo." },
            art7_3_title: { en: "7.3 Communication", sw: "7.3 Mawasiliano" },
            art7_3_text: { en: "All official communication shall be through the FamilyFund Management System, email, or a designated WhatsApp group. Meeting minutes and decisions will be published within 7 days.", sw: "Mawasiliano yote rasmi yatafanyika kupitia Mfumo wa Usimamizi wa FamilyFund, barua pepe, au kikundi maalum cha WhatsApp. Kumbukumbu za mikutano na maamuzi vitachapishwa ndani ya siku 7." },
            // Article 8
            art8Badge: { en: "Article 8", sw: "Kifungu cha 8" },
            art8Title: { en: "Amendments and Dissolution", sw: "Marekebisho na Kufutwa" },
            art8_1_title: { en: "8.1 Amendments", sw: "8.1 Marekebisho" },
            art8_1_text: { en: "This Constitution may be amended by a two-thirds majority vote of all members present at a properly convened meeting, provided the proposed amendment has been circulated at least 14 days in advance.", sw: "Katiba hii inaweza kurekebishwa kwa kura ya theluthi mbili ya wanachama wote waliopo kwenye mkutano ulioitishwa ipasavyo, mradi pendekezo la marekebisho limezungushwa angalau siku 14 kabla." },
            art8_2_title: { en: "8.2 Dissolution", sw: "8.2 Kufutwa" },
            art8_2_text: { en: "The Fund may be dissolved by a unanimous vote of all members. Upon dissolution, all assets shall be distributed to members in proportion to their total contributions after settling any outstanding liabilities.", sw: "Mfuko unaweza kufutwa kwa kura ya pamoja ya wanachama wote. Baada ya kufutwa, mali zote zitasambazwa kwa wanachama kulingana na michango yao jumla baada ya kumaliza madeni yoyote." },
            // Footer
            footerTitle: { en: "Official Document Status", sw: "Hali ya Hati Rasmi" },
            footerAdopted: { en: "This Constitution was adopted and comes into force on <strong>December 22, 2025</strong>.", sw: "Katiba hii ilipitishwa na kuanza kutumika tarehe <strong>Desemba 22, 2025</strong>." },
            footerNote: { en: "This document should be read in conjunction with the official <strong>FamilyFund Terms of Service</strong> and any operational <strong>Bylaws</strong> established by the Management Team.", sw: "Hati hii inapaswa kusomwa pamoja na <strong>Masharti ya Huduma ya FamilyFund</strong> na <strong>Kanuni zozote za Uendeshaji</strong> zilizowekwa na Timu ya Usimamizi." },
            // Navigation
            navTitle: { en: "Constitution Navigation", sw: "Urambazaji wa Katiba" },
            navPreamble: { en: "Preamble", sw: "Utangulizi" },
            navArt1: { en: "Article 1: Name & Office", sw: "Kifungu cha 1: Jina na Ofisi" },
            navArt2: { en: "Article 2: Objectives", sw: "Kifungu cha 2: Malengo" },
