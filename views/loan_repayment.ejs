
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Loan Repayment - FamilyFund</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

  <!-- Custom CSS -->
  <link href="/css/app.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/flash.css">

  <style>
    .repayment-card {
      max-width: 700px;
      margin: 0 auto;
      background: white;
      border-radius: 10px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.1);
      padding: 25px;
    }
    .form-title {
      color: #2c3e50;
      border-left: 5px solid #3498db;
      padding-left: 15px;
      margin-bottom: 25px;
    }
    .loan-summary {
      background-color: #f8f9fa;
      border-radius: 8px;
      padding: 15px;
      margin-top: 20px;
      display: none;
    }
    .loan-summary.show {
      display: block;
    }
  </style>
</head>
<body class="financial-statement-page">
  <%- include('partials/header') %>
  <%- include('partials/sidebar', { user: user }) %>
  <%- include('partials/change_password_modal') %>

  <main class="main-content">
    <div class="container-fluid pt-5 mt-3">
      <div class="row">
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
          <%- include('partials/flash') %>

          <div class="repayment-card">
            <h2 class="form-title"><i class="fas fa-hand-holding-usd me-2"></i>Loan Repayment</h2>

            <% if (loans.length === 0) { %>
              <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i> There are no approved loans pending repayment at this time.
              </div>
              <div class="text-center mt-3">
                <a href="/dashboard" class="btn btn-secondary">Back to Dashboard</a>
              </div>
            <% } else { %>
              <form id="repaymentForm" action="/loans/repayment" method="POST">
                <div class="mb-3">
                  <label for="loanId" class="form-label">Select Loan <span class="text-danger">*</span></label>
                  <select name="loanId" id="loanId" class="form-select" required>
                    <option value="">-- Choose a loan --</option>
                    <% loans.forEach(loan => { %>
                      <option value="<%= loan.id %>"
                              data-member="<%= loan.first_name %> <%= loan.sur_name %>"
                              data-amount="<%= loan.amount %>"
                              data-monthly="<%= loan.monthly_payment %>"
                              data-remaining="<%= loan.remaining_balance %>">
                        Loan #<%= loan.id %> – <%= loan.first_name %> <%= loan.sur_name %> (TSh <%= loan.amount.toLocaleString() %>)
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div id="loanSummary" class="loan-summary">
                  <h5>Loan Details</h5>
                  <p><strong>Member:</strong> <span id="summaryMember"></span></p>
                  <p><strong>Original Amount:</strong> TSh <span id="summaryAmount"></span></p>
                  <p><strong>Monthly Payment:</strong> TSh <span id="summaryMonthly"></span></p>
                  <p><strong>Remaining Balance:</strong> TSh <span id="summaryRemaining"></span></p>
                </div>

                <div class="mb-3">
                  <label for="amount" class="form-label">Payment Amount (TSh) <span class="text-danger">*</span></label>
                  <input type="number" name="amount" id="amount" class="form-control" min="1" required>
                  <small class="text-muted">You may pay any amount up to the remaining balance.</small>
                </div>

                <div class="mb-3">
                  <label for="notes" class="form-label">Notes (Optional)</label>
                  <textarea name="notes" id="notes" class="form-control" rows="2" placeholder="Additional notes about the payment..."></textarea>
                </div>

                <div class="d-flex justify-content-between mt-4">
                  <a href="/dashboard" class="btn btn-secondary">Cancel</a>
                  <button type="submit" class="btn btn-primary">Record Payment</button>
                </div>
              </form>
            <% } %>
          </div>
        </main>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/script/dashboard.js"></script>
  <script src="/script/sidebar.js"></script>
  <script src="/js/flash.js"></script>
  <script>
    // Show loan summary when a loan is selected
    const loanSelect = document.getElementById('loanId');
    const loanSummaryDiv = document.getElementById('loanSummary');
    const summaryMember = document.getElementById('summaryMember');
    const summaryAmount = document.getElementById('summaryAmount');
    const summaryMonthly = document.getElementById('summaryMonthly');
    const summaryRemaining = document.getElementById('summaryRemaining');

    loanSelect.addEventListener('change', function() {
      const selectedOption = this.options[this.selectedIndex];
      if (this.value) {
        summaryMember.textContent = selectedOption.dataset.member;
        summaryAmount.textContent = Number(selectedOption.dataset.amount).toLocaleString();
        summaryMonthly.textContent = Number(selectedOption.dataset.monthly).toLocaleString();
        summaryRemaining.textContent = Number(selectedOption.dataset.remaining).toLocaleString();
        loanSummaryDiv.classList.add('show');
      } else {
        loanSummaryDiv.classList.remove('show');
      }
    });
  </script>
</body>
</html>


