
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Support Message Details - FamilyFund Admin</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom CSS -->
    <link href="/css/app.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/flash.css">
    
    <style>
        .message-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 10px 10px 0 0;
            padding: 1.5rem;
        }
        
        .message-body {
            background: #f8f9fa;
            padding: 2rem;
            border-radius: 0 0 10px 10px;
            margin-bottom: 2rem;
        }
        
        .urgency-badge, .status-badge {
            font-size: 0.9rem;
            padding: 0.5rem 1rem;
            border-radius: 5px;
        }
        
        .message-content {
            background: white;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 1.5rem;
            margin: 1.5rem 0;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
        
        .info-item {
            padding: 0.5rem 0;
            border-bottom: 1px solid #eee;
        }
        
        .info-item:last-child {
            border-bottom: none;
        }
        
        .admin-notes {
            background: #fff3cd;
            border: 1px solid #ffc107;
            border-radius: 8px;
            padding: 1.5rem;
            margin: 1.5rem 0;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

  <!-- Header -->
  <%- include('../partials/header') %>

  <!-- Sidebar -->
  <%- include('../partials/sidebar', { user: user, activePage: 'admin_support' }) %>

  <main class="main-content">
    <div class="container-fluid pt-5 mt-3">
      <div class="row">
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
          
          <%- include('../partials/flash') %>
          
          <!-- Back button -->
          <div class="mb-4">
            <a href="/admin/support" class="btn btn-outline-secondary">
              <i class="fas fa-arrow-left me-2"></i>Back to Messages
            </a>
          </div>

          <!-- Message Header -->
          <div class="card mb-4">
            <div class="message-header">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <h1 class="h4 mb-2">Support Message #<%= message.id %></h1>
                  <p class="mb-0 opacity-75">Detailed view and management</p>
                </div>
                <div class="text-end">
                  <div class="mb-2">
                    <% const urgencyClass = {
                      'critical': 'bg-danger',
                      'high': 'bg-warning',
                      'medium': 'bg-info',
                      'low': 'bg-secondary'
                    }[message.urgency] || 'bg-secondary' %>
                    <span class="badge <%= urgencyClass %> urgency-badge">
                      <%= message.urgency.toUpperCase() %> URGENCY
                    </span>
                  </div>
                  <div>
                    <% const statusClass = {
                      'new': 'bg-danger',
                      'in_progress': 'bg-warning',
                      'resolved': 'bg-success',
                      'closed': 'bg-secondary'
                    }[message.status] || 'bg-secondary' %>
                    <span class="badge <%= statusClass %> status-badge">
                      <%= message.status.replace('_', ' ').toUpperCase() %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="message-body">
              <!-- Message Information -->
              <div class="row mb-4">
                <div class="col-md-6">
                  <div class="card">
                    <div class="card-header bg-light">
                      <h6 class="mb-0"><i class="fas fa-user me-2"></i>Sender Information</h6>
                    </div>
                    <div class="card-body">
                      <div class="info-item">
                        <strong>Name:</strong> <%= message.name %>
                      </div>
                      <div class="info-item">
                        <strong>Email:</strong> <%= message.email %>
                      </div>
                      <% if (message.user_username) { %>
                        <div class="info-item">
                          <strong>User Account:</strong> <%= message.user_username %>
                        </div>
                      <% } %>
                      <% if (message.member_first_name) { %>
                        <div class="info-item">
                          <strong>Member:</strong> <%= message.member_first_name %> <%= message.member_sur_name %>
                        </div>
                      <% } %>
                    </div>
                  </div>
                </div>
                
                <div class="col-md-6">
                  <div class="card">
                    <div class="card-header bg-light">
                      <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Message Details</h6>
                    </div>
                    <div class="card-body">
                      <div class="info-item">
                        <strong>Subject:</strong> <%= message.subject %>
                      </div>
                      <div class="info-item">
                        <strong>Submitted:</strong> <%= new Date(message.created_at).toLocaleString() %>
                      </div>
                      <div class="info-item">
                        <strong>Last Updated:</strong> <%= message.updated_at ? new Date(message.updated_at).toLocaleString() : 'Never' %>
                      </div>
                      <% if (message.resolved_at) { %>
                        <div class="info-item">
                          <strong>Resolved:</strong> <%= new Date(message.resolved_at).toLocaleString() %>
                        </div>
                      <% } %>
                      <% if (message.assigned_username) { %>
                        <div class="info-item">
                          <strong>Assigned To:</strong> <%= message.assigned_username %>
                        </div>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Message Content -->
              <div class="card mb-4">
                <div class="card-header bg-light">
                  <h6 class="mb-0"><i class="fas fa-envelope me-2"></i>Message Content</h6>
                </div>
                <div class="card-body">
                  <div class="message-content">
                    <%= message.message %>
                  </div>
                </div>
              </div>

              <!-- Admin Notes (if any) -->
              <% if (message.admin_notes) { %>
                <div class="admin-notes">
                  <h6 class="text-warning">
                    <i class="fas fa-sticky-note me-2"></i>Admin Notes
                  </h6>
                  <p class="mb-0"><%= message.admin_notes %></p>
                </div>
              <% } %>

              <!-- Update Status Form -->
              <div class="card">
                <div class="card-header bg-light">
                  <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Update Status</h6>
                </div>
                <div class="card-body">
                  <form method="POST" action="/admin/support/<%= message.id %>/update-status">
                    <div class="row g-3">
                      <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <select name="status" class="form-select" required>
                          <option value="new" <%= message.status === 'new' ? 'selected' : '' %>>New</option>
                          <option value="in_progress" <%= message.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                          <option value="resolved" <%= message.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
                          <option value="closed" <%= message.status === 'closed' ? 'selected' : '' %>>Closed</option>
                        </select>
                      </div>
                      <div class="col-md-8">
                        <label class="form-label">Admin Notes (Optional)</label>
                        <textarea name="admin_notes" class="form-control" rows="2" placeholder="Add notes about this message..."><%= message.admin_notes || '' %></textarea>
                      </div>
                      <div class="col-12">
                        <div class="d-flex justify-content-between">
                          <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Update Status
                          </button>
                          <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                            <i class="fas fa-times me-2"></i>Cancel
                          </button>
                        </div>
                      </div>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>

        </main>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
      
  <script src="/js/flash.js"></script>
  <script src="/script/dashboard.js"></script>

</body>
</html>


