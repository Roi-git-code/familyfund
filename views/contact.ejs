                  <div class="support-option">
                    <h6 class="text-success">+255 698 778 560 / +255 747 306 515 </h6>
                    <small class="text-muted">General support hotline</small>
                  </div>
                  <div class="support-option">
                    <h6 class="text-success">+255 748 033 536</h6>
