  <%- include('partials/footer') %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
      
    <script src="/js/flash.js"></script>
    <script src="/script/dashboard.js"></script>
    <script src="/script/sidebar.js"></script>

<script>
    // Enhanced alert function
    function showAlert(type, message, duration = 8000) {
        // Remove existing alerts
        const existingAlerts = document.querySelectorAll('.auto-alert');
        existingAlerts.forEach(alert => alert.remove());
        
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show auto-alert alert-fixed`;
        alertDiv.innerHTML = `
            <div class="d-flex align-items-center">
                <i class="fas ${getAlertIcon(type)} me-2"></i>
                <div class="flex-grow-1">${message}</div>
                <button type="button" class="btn-close ms-3" data-bs-dismiss="alert"></button>
            </div>
        `;
        
        document.body.appendChild(alertDiv);
        
        // Auto remove after duration
        setTimeout(() => {
            if (alertDiv.parentElement) {
                alertDiv.remove();
            }
        }, duration);
    }

    function getAlertIcon(type) {
        switch(type) {
            case 'success': return 'fa-check-circle';
            case 'danger': return 'fa-exclamation-circle';
            case 'warning': return 'fa-exclamation-triangle';
            default: return 'fa-info-circle';
        }
    }

    // Live chat simulation
    function startLiveChat() {
        const isOnline = Math.random() > 0.2;
        
        if (isOnline) {
            showAlert('success', 'Connecting you to a support agent...');
            setTimeout(() => {
                showAlert('info', 'Chat session started. Please check the bottom right corner of your screen.');
            }, 1000);
        } else {
            showAlert('warning', 'Our chat support is currently offline. Please try email or phone support.');
        }
    }

    // Character counter for message
    const messageTextarea = document.getElementById('message');
    if (messageTextarea) {
        const charCounter = document.getElementById('charCounter');
        
        messageTextarea.addEventListener('input', function() {
            const length = this.value.length;
            document.getElementById('charCount').textContent = length;
            
            if (length > 1800) {
                charCounter.classList.add('warning');
                charCounter.innerHTML = `<span id="charCount">${length}</span>/2000 characters - <strong>${2000 - length} characters left</strong>`;
            } else {
                charCounter.classList.remove('warning');
                charCounter.innerHTML = `<span id="charCount">${length}</span>/2000 characters`;
            }
        });
    }

    // Simple form validation for submission
    function validateForm() {
        console.log('🔍 Form validation started');
        
        const name = document.getElementById('name').value.trim();
        const email = document.getElementById('email').value.trim();
        const subject = document.getElementById('subject').value;
        const message = document.getElementById('message').value.trim();
        
        console.log('📋 Form values:', { name, email, subject, message });
        
        let errors = [];
        
        if (!name) {
            errors.push('Name is required');
            document.getElementById('name').classList.add('is-invalid');
        } else {
            document.getElementById('name').classList.remove('is-invalid');
        }

        if (!email) {
            errors.push('Email is required');
            document.getElementById('email').classList.add('is-invalid');
        } else {
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                errors.push('Please enter a valid email address');
                document.getElementById('email').classList.add('is-invalid');
            } else {
                document.getElementById('email').classList.remove('is-invalid');
            }
        }

        if (!subject) {
            errors.push('Subject is required');
            document.getElementById('subject').classList.add('is-invalid');
        } else {
            document.getElementById('subject').classList.remove('is-invalid');
        }

        if (!message) {
            errors.push('Message is required');
            document.getElementById('message').classList.add('is-invalid');
        } else if (message.length < 10) {
            errors.push('Message must be at least 10 characters');
            document.getElementById('message').classList.add('is-invalid');
        } else if (message.length > 2000) {
            errors.push('Message is too long (maximum 2000 characters)');
            document.getElementById('message').classList.add('is-invalid');
        } else {
            document.getElementById('message').classList.remove('is-invalid');
        }
        
        // Clear any existing alerts
        const existingAlerts = document.querySelectorAll('.auto-alert');
        existingAlerts.forEach(alert => alert.remove());
        
        if (errors.length > 0) {
            console.error('❌ Validation errors:', errors);
            showAlert('warning', errors.join(', '), 5000);
            return false; // Prevent form submission
        }
        
        console.log('✅ Form validation passed');
        
        // Show loading state
        const submitBtn = document.getElementById('submitBtn');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Sending...';
        submitBtn.disabled = true;
        
        // Re-enable button after 5 seconds in case something goes wrong
        setTimeout(() => {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }, 5000);
        
        return true; // Allow form submission
    }

    // File upload validation (optional - keep if you want)
    const fileInput = document.getElementById('attachments');
    if (fileInput) {
        fileInput.addEventListener('change', validateFiles);
    }

    function validateFiles() {
        const files = this.files;
        const maxSize = 10 * 1024 * 1024; // 10MB
        const maxFiles = 5;
        let totalSize = 0;

        if (files.length > maxFiles) {
            showAlert('warning', `Maximum ${maxFiles} files allowed. You selected ${files.length}.`);
            this.value = '';
            return;
        }

        for (let i = 0; i < files.length; i++) {
            totalSize += files[i].size;
            if (files[i].size > maxSize) {
                showAlert('warning', `File "${files[i].name}" is too large. Maximum size is 10MB.`);
                this.value = '';
                return;
            }
        }

        if (totalSize > maxSize) {
            showAlert('warning', 'Total file size exceeds 10MB limit.');
            this.value = '';
        }
    }

    // Auto-fill subject based on urgency
    document.getElementById('urgency').addEventListener('change', function() {
        const subject = document.getElementById('subject');
        if (this.value === 'high' || this.value === 'critical') {
            if (!subject.value) {
                subject.value = 'technical';
            }
        }
    });

    // Clear validation styles when user starts typing
    const formInputs = document.querySelectorAll('#supportForm input, #supportForm select, #supportForm textarea');
    formInputs.forEach(input => {
        input.addEventListener('input', function() {
            this.classList.remove('is-invalid');
            // Clear any auto-alerts when user starts typing
            const alerts = document.querySelectorAll('.auto-alert');
            alerts.forEach(alert => {
                if (alert.textContent.includes(this.name) || alert.textContent.includes(this.id)) {
                    alert.remove();
                }
            });
        });
    });

    // Display messages from URL parameters on page load
    window.addEventListener('load', function() {
        console.log('🚀 Support page loaded');
        
        // Check for URL parameters
        const urlParams = new URLSearchParams(window.location.search);
        const success = urlParams.get('success');
        const error = urlParams.get('error');
        
        if (success) {
            showAlert('success', decodeURIComponent(success));
            // Clean URL without page reload
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
        }
        
        if (error) {
            showAlert('danger', decodeURIComponent(error));
            // Clean URL without page reload
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
        }
        
        // Auto-fill form with user data if available
        const user = <% if (user) { %> <%- JSON.stringify(user) %> <% } else { %> null <% } %>;
        if (user) {
            console.log('👤 User data available:', user);
            
            // Auto-fill email if empty
            const emailField = document.getElementById('email');
            if (emailField && !emailField.value && user.username) {
                emailField.value = user.username;
            }
            
            // Auto-fill name if empty
            const nameField = document.getElementById('name');
            if (nameField && !nameField.value) {
                const fullName = `${user.first_name || ''} ${user.sur_name || ''}`.trim();
                if (fullName) {
                    nameField.value = fullName;
                }
            }
        }
        
        // Initialize character counter
        if (messageTextarea && messageTextarea.value) {
            const length = messageTextarea.value.length;
            document.getElementById('charCount').textContent = length;
            if (length > 1800) {
                document.getElementById('charCounter').classList.add('warning');
            }
        }
        
    });

    // Add input validation for email as user types
    document.getElementById('email').addEventListener('blur', function() {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (this.value && !emailRegex.test(this.value)) {
            this.classList.add('is-invalid');
            showAlert('warning', 'Please enter a valid email address', 3000);
        } else {
            this.classList.remove('is-invalid');
        }
    });

    // Add input validation for message length
    document.getElementById('message').addEventListener('blur', function() {
        if (this.value && this.value.length < 10) {
            this.classList.add('is-invalid');
            showAlert('warning', 'Message should be at least 10 characters', 3000);
        } else if (this.value.length > 2000) {
            this.classList.add('is-invalid');
            showAlert('warning', 'Message exceeds 2000 characters', 3000);
        } else {
            this.classList.remove('is-invalid');
        }
    });
</script>
      
</body>
</html>


