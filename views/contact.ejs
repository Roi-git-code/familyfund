                  <div class="support-option">
                    <h6 class="text-warning">Online Chat</h6>
                    <small class="text-muted">Available during business hours</small>
                  </div>
                  <div class="support-option">
                    <h6 class="text-warning">WhatsApp Business</h6>
                    <small class="text-muted"> +255 698 778 560 / +255 747 306 515  </small>
                  </div>
                  <div class="mt-3">
                    <span class="badge bg-success">
                      <i class="fas fa-circle me-1"></i>
                      Online Now
