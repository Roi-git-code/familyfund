<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Restructure Loan - FamilyFund</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="/css/app.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/flash.css">
</head>
<body class="financial-statement-page">
  <%- include('partials/header') %>
  <%- include('partials/sidebar', { user: user }) %>

  <main class="main-content">
    <div class="container-fluid pt-5 mt-3">
      <div class="row">
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
          <%- include('partials/flash') %>

          <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
              <h4 class="mb-0"><i class="fas fa-sync-alt me-2"></i>Request Loan Restructuring</h4>
            </div>
            <div class="card-body">
              <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Loan #<%= loan.id %></strong> – <%= loan.loan_type === 'service' ? 'Service Loan' : 'Investment Loan' %><br>
                Current tenure: <strong><%= loan.tenure_months %> months</strong><br>
                Remaining balance: <strong>TSh <%= Number(loan.remaining_balance).toLocaleString() %></strong><br>
                Current monthly payment: <strong>TSh <%= Number(loan.monthly_payment).toLocaleString() %></strong><br>
                Maximum new tenure: <strong><%= loan.loan_type === 'service' ? 12 : 24 %> months</strong>
              </div>

              <form method="POST">
                <div class="mb-3">
                  <label for="new_tenure" class="form-label">New Tenure (months) <span class="text-danger">*</span></label>
                  <input type="number" name="new_tenure" id="new_tenure" class="form-control" 
                         min="1" max="<%= loan.loan_type === 'service' ? 12 : 24 %>" required>
                  <div class="form-text">Enter the new repayment period. The monthly payment will be recalculated based on the remaining balance.</div>
                </div>

                <div class="mb-3">
                  <label for="reason" class="form-label">Reason for Restructuring</label>
                  <textarea name="reason" id="reason" class="form-control" rows="4" placeholder="Explain why you need to extend or shorten the repayment period..."></textarea>
                </div>

                <div class="d-flex justify-content-between">
                  <a href="/my-loans" class="btn btn-secondary">Cancel</a>
                  <button type="submit" class="btn btn-primary">Submit Request</button>
                </div>
              </form>
            </div>
          </div>
        </main>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/script/dashboard.js"></script>
  <script src="/script/sidebar.js"></script>
  <script src="/js/flash.js"></script>
</body>
</html>


