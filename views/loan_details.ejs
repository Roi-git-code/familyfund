
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loan Details - FamilyFund</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="/css/app.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/flash.css">
    <style>
        .loan-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 10px 10px 0 0; }
        .loan-summary { padding: 20px; background: #f8f9fa; border-radius: 0 0 10px 10px; margin-bottom: 30px; }
        .schedule-table { max-height: 400px; overflow-y: auto; }
        .badge-status { font-size: 0.9rem; padding: 5px 12px; border-radius: 20px; }
        .status-Pending { background: #ffc107; color: #856404; }
        .status-Under-Review { background: #17a2b8; color: white; }
        .status-Approved { background: #28a745; color: white; }
        .status-Rejected { background: #dc3545; color: white; }
        .status-Completed { background: #6c757d; color: white; }
        .status-Restructured { background: #6f42c1; color: white; }
    </style>
</head>
<body class="financial-statement-page">
    <%- include('partials/header') %>
    <%- include('partials/sidebar', { user: user }) %>

    <main class="main-content">
        <div class="container-fluid pt-5 mt-3">
            <div class="row">
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                    <%- include('partials/flash') %>

                    <div class="card shadow">
                        <div class="loan-header">
                            <h2>Loan #<%= loan.id %></h2>
                            <p class="mb-0"><%= loan.loan_type === 'service' ? 'Service Loan' : 'Investment Loan' %></p>
                        </div>
                        <div class="loan-summary">
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong>Member:</strong> <%= loan.first_name %> <%= loan.sur_name %></p>
                                    <p><strong>Principal Amount:</strong> TSh <%= Number(loan.amount).toLocaleString() %></p>
                                    <p><strong>Interest Rate:</strong> <%= loan.interest_rate %>% p.a.</p>
                                    <p><strong>Tenure:</strong> <%= loan.tenure_months %> months</p>
                                    <p><strong>Monthly Payment (EMI):</strong> TSh <%= Number(loan.monthly_payment).toLocaleString() %></p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Total Repayable:</strong> TSh <%= Number(loan.total_repayable).toLocaleString() %></p>
                                    <p><strong>Paid Amount:</strong> TSh <%= Number(loan.paid_amount).toLocaleString() %></p>
                                    <p><strong>Remaining Balance:</strong> TSh <%= Number(loan.remaining_balance).toLocaleString() %></p>
                                    <p><strong>Status:</strong> 
                                        <span class="badge-status status-<%= loan.status.replace(' ', '-') %>"><%= loan.status %></span>
                                    </p>
                                    <p><strong>Applied:</strong> <%= new Date(loan.created_at).toLocaleString() %></p>
                                    <% if (loan.reason) { %>
                                        <p><strong>Rejection Reason:</strong> <span class="text-danger"><%= loan.reason %></span></p>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Parent loan info (if this loan is a restructured version) -->
                            <% if (loan.parent_loan) { %>
                                <div class="alert alert-info mt-3">
                                    <strong><i class="fas fa-link me-2"></i>This loan is a restructured version of Loan #<%= loan.parent_loan.id %></strong><br>
                                    Original amount: TSh <%= Number(loan.parent_loan.amount).toLocaleString() %><br>
                                    Original status: <%= loan.parent_loan.status %>
                                </div>
                            <% } %>

                            <!-- Children loans (if this loan has been restructured) -->
                            <% if (loan.restructured_loans && loan.restructured_loans.length > 0) { %>
                                <div class="alert alert-warning mt-3">
                                    <strong><i class="fas fa-code-branch me-2"></i>This loan has been restructured into the following loan(s):</strong>
                                    <ul>
                                        <% loan.restructured_loans.forEach(child => { %>
                                            <li><a href="/loans/<%= child.id %>">Loan #<%= child.id %></a> – TSh <%= Number(child.amount).toLocaleString() %> (Status: <%= child.status %>)</li>
                                        <% }) %>
                                    </ul>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Tabs -->
                    <ul class="nav nav-tabs mt-4" id="loanTabs" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active" id="schedule-tab" data-bs-toggle="tab" data-bs-target="#schedule" type="button" role="tab">Repayment Schedule</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab">Restructuring History</button>
                        </li>
                    </ul>

                    <div class="tab-content mt-3">
                        <!-- Repayment Schedule Tab -->
                        <div class="tab-pane fade show active" id="schedule" role="tabpanel">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h5><i class="fas fa-calendar-alt me-2"></i>Repayment Schedule</h5>
                                </div>
                                <div class="card-body schedule-table">
                                    <table class="table table-striped table-hover">
                                        <thead>
                                            32<th>#</th>
                                                <th>Due Date</th>
                                                <th>Amount Due (TSh)</th>
                                                <th>Amount Paid (TSh)</th>
                                                <th>Status</th>
                                                <th>Payment Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (loan.repayments && loan.repayments.length > 0) { %>
                                                <% loan.repayments.forEach((rep, idx) => { %>
                                                    <tr>
                                                        <td><%= idx + 1 %></td>
                                                        <td><%= new Date(rep.due_date).toLocaleDateString() %></td>
                                                        <td><%= Number(rep.amount_due).toLocaleString() %></td>
                                                        <td><%= Number(rep.amount_paid).toLocaleString() %></td>
                                                        <td>
                                                            <% if (rep.status === 'Paid') { %>
                                                                <span class="badge bg-success">Paid</span>
                                                            <% } else if (rep.status === 'Partial') { %>
                                                                <span class="badge bg-warning">Partial</span>
                                                            <% } else if (rep.status === 'Overdue') { %>
                                                                <span class="badge bg-danger">Overdue</span>
                                                            <% } else { %>
                                                                <span class="badge bg-secondary">Pending</span>
                                                            <% } %>
                                                         </td>
                                                        <td><%= rep.payment_date ? new Date(rep.payment_date).toLocaleDateString() : '—' %></td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr><td colspan="6" class="text-center">No repayment records found.</td></tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Restructuring History Tab (unchanged) -->
                        <div class="tab-pane fade" id="history" role="tabpanel">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h5><i class="fas fa-history me-2"></i>Restructuring History</h5>
                                </div>
                                <div class="card-body">
                                    <% if (restructuringHistory && restructuringHistory.length > 0) { %>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered">
                                                <thead class="table-dark">
                                                    <tr><th>Date</th><th>Old Tenure</th><th>New Tenure</th><th>Old Monthly</th><th>New Monthly</th><th>Old Total Repayable</th><th>New Total Repayable</th><th>Reason</th><th>Approved By</th></tr>
                                                </thead>
                                                <tbody>
                                                    <% restructuringHistory.forEach(hist => { %>
                                                        <tr>
                                                            <td><%= new Date(hist.restructured_at).toLocaleString() %></td>
                                                            <td><%= hist.old_tenure_months ? hist.old_tenure_months + ' months' : 'N/A' %></td>
                                                            <td><%= hist.new_tenure_months %> months</td>
                                                            <td><%= hist.old_monthly_payment ? 'TSh ' + Number(hist.old_monthly_payment).toLocaleString() : 'N/A' %></td>
                                                            <td>TSh <%= Number(hist.new_monthly_payment).toLocaleString() %></td>
                                                            <td><%= hist.old_total_repayable ? 'TSh ' + Number(hist.old_total_repayable).toLocaleString() : 'N/A' %></td>
                                                            <td>TSh <%= Number(hist.new_total_repayable).toLocaleString() %></td>
                                                            <td><%= hist.reason || 'N/A' %></td>
                                                            <td><%= hist.approved_by_name ? hist.approved_by_name + ' ' + hist.approved_by_surname : 'System' %></td>
                                                        </tr>
                                                    <% }) %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } else { %>
                                        <div class="alert alert-info">No restructuring history for this loan.</div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-between">
                        <a href="/my-loans" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i> Back to My Loans</a>
                        <% if (user.role === 'chief_signatory' || user.role === 'assistant_signatory') { %>
                            <a href="/loans/<%= loan.id %>/download" class="btn btn-primary"><i class="fas fa-download me-1"></i> Download Schedule (PDF)</a>
                        <% } %>
                    </div>
                </main>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/script/dashboard.js"></script>
    <script src="/script/sidebar.js"></script>
    <script src="/js/flash.js"></script>
</body>
</html>


