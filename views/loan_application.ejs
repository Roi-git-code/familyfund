
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Loan Application - FamilyFund</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

  <!-- Custom CSS -->
  <link href="/css/app.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/flash.css">

  <style>
    .loan-application-container {
      max-width: 800px;
      margin: 0 auto;
    }
    .loan-form-card {
      background: white;
      border-radius: 10px;
      padding: 30px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.1);
      margin-bottom: 30px;
    }
    .form-title {
      color: #2c3e50;
      border-left: 5px solid #3498db;
      padding-left: 15px;
      margin-bottom: 30px;
    }
    .info-note {
      background: #e8f4fd;
      border-left: 4px solid #3498db;
      padding: 10px 15px;
      margin-bottom: 20px;
      border-radius: 5px;
    }
    /* Toggle buttons */
    .loan-toggle {
      display: flex;
      gap: 15px;
      margin-bottom: 30px;
      border-bottom: 2px solid #e9ecef;
      padding-bottom: 10px;
    }
    .toggle-btn {
      background: none;
      border: none;
      font-size: 1.1rem;
      font-weight: 600;
      padding: 10px 20px;
      border-radius: 30px;
      transition: all 0.3s ease;
      cursor: pointer;
      color: #6c757d;
    }
    .toggle-btn.active {
      background: #3498db;
      color: white;
      box-shadow: 0 2px 8px rgba(52,152,219,0.3);
    }
    .toggle-btn:hover:not(.active) {
      background: #f8f9fa;
      color: #2c3e50;
    }
    .loan-type-card {
      border: 1px solid #dee2e6;
      border-radius: 8px;
      padding: 15px;
      transition: all 0.3s;
      background: white;
    }
    .loan-type-card:hover {
      box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    }
    .badge-rate {
      font-size: 1rem;
      background: #2c3e50;
      color: white;
      padding: 5px 12px;
      border-radius: 30px;
      display: inline-block;
      margin-bottom: 10px;
    }
  </style>
</head>
<body class="financial-statement-page">
  <%- include('partials/header') %>
  <%- include('partials/sidebar', { user: user }) %>
  <%- include('partials/change_password_modal') %>

  <main class="main-content">
    <div class="container-fluid pt-5 mt-3">
      <div class="row">
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
          <%- include('partials/flash') %>

          <div class="loan-application-container">
            <div class="loan-form-card">
              <h2 class="form-title"><i class="fas fa-hand-holding-usd me-2"></i>Loan Application</h2>

              <div class="info-note">
                <i class="fas fa-info-circle me-2"></i> 
                Please read the <a href="/constitution#article6" target="_blank">Loan Policies (Article 6)</a> before applying.
              </div>

              <!-- Toggle buttons -->
              <div class="loan-toggle">
                <button type="button" class="toggle-btn active" data-loan="service">Service Loan</button>
                <button type="button" class="toggle-btn" data-loan="investment">Investment Loan</button>
              </div>

              <form action="/loan-application" method="POST" enctype="multipart/form-data">
                <% if (typeof csrfToken !== 'undefined') { %>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>

                <!-- Hidden field to store selected loan type -->
                <input type="hidden" name="loan_type" id="selected_loan_type" value="service">

                <!-- Service Loan Card (visible by default) -->
                <div id="service_card" class="loan-type-card">
                  <div class="badge-rate">12% p.a. (Reducing Balance)</div>
                  <h5><i class="fas fa-briefcase me-2"></i>Service Loan</h5>
                  <p>For personal needs: education fees, medical expenses, home repairs, etc.</p>
                  <ul class="small text-muted">
                    <li>Max amount: TSh 500,000</li>
                    <li>Repayment: Up to 12 months</li>
                  </ul>
                </div>

                <!-- Investment Loan Card (hidden by default) -->
                <div id="investment_card" class="loan-type-card" style="display: none;">
                  <div class="badge-rate">13% p.a. (Reducing Balance)</div>
                  <h5><i class="fas fa-chart-line me-2"></i>Investment Loan</h5>
                  <p>For business or income-generating projects. Requires project proposal.</p>
                  <ul class="small text-muted">
                    <li>Max amount: TSh 2,000,000</li>
                    <li>Repayment: Up to 24 months</li>
                  </ul>
                </div>

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label for="amount" class="form-label">Amount Requested (TSh) <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" id="amount" name="amount" step="10000" min="10000" required>
                    <small class="text-muted">Minimum 10,000. Maximum depends on loan type.</small>
                  </div>
                  <div class="col-md-6 mb-3">
                    <label for="tenure_months" class="form-label">Tenure (Months) <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" id="tenure_months" name="tenure_months" min="1" max="24" required>
                    <small class="text-muted">Service loans: max 12 months; Investment loans: max 24 months.</small>
                  </div>
                </div>

                <div class="mb-3">
                  <label for="purpose" class="form-label">Purpose of Loan <span class="text-danger">*</span></label>
                  <textarea class="form-control" id="purpose" name="purpose" rows="3" required placeholder="Explain why you need this loan..."></textarea>
                </div>

                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label for="bankAccount" class="form-label">Bank Account / Mobile Money Number <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="bankAccount" name="bankAccount" required pattern="\d{6,20}" title="Must be 6-20 digits">
                  </div>
                  <div class="col-md-6 mb-3">
                    <label for="bankName" class="form-label">Bank / Mobile Money Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="bankName" name="bankName" required>
                  </div>
                </div>

                <div class="mb-3">
                  <label for="additionalInfo" class="form-label">Additional Information (Optional)</label>
                  <textarea class="form-control" id="additionalInfo" name="additionalInfo" rows="3"></textarea>
                </div>

                <div class="mb-3">
                  <label for="supportingDoc" class="form-label">Supporting Documents</label>
                  <input type="file" class="form-control" id="supportingDoc" name="supportingDoc" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx">
                  <small class="text-muted">Max 5 files. Acceptable formats: PDF, DOC, DOCX, JPG, PNG.</small>
                </div>

                <div class="d-flex justify-content-between mt-4">
                  <a href="/dashboard" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i> Cancel</a>
                  <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane me-1"></i> Submit Application</button>
                </div>
              </form>
            </div>
          </div>
        </main>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <!-- JavaScript Libraries -->
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/script/dashboard.js"></script>
  <script src="/script/sidebar.js"></script>
  <script src="/js/flash.js"></script>

  <script>
    // Toggle between loan types
    const serviceCard = document.getElementById('service_card');
    const investmentCard = document.getElementById('investment_card');
    const toggleBtns = document.querySelectorAll('.toggle-btn');
    const loanTypeInput = document.getElementById('selected_loan_type');
    const amountInput = document.getElementById('amount');
    const tenureInput = document.getElementById('tenure_months');

    function setActiveLoan(type) {
      if (type === 'service') {
        serviceCard.style.display = 'block';
        investmentCard.style.display = 'none';
        loanTypeInput.value = 'service';
        amountInput.max = 500000;
        tenureInput.max = 12;
        amountInput.placeholder = 'Max 500,000';
      } else {
        serviceCard.style.display = 'none';
        investmentCard.style.display = 'block';
        loanTypeInput.value = 'investment';
        amountInput.max = 2000000;
        tenureInput.max = 24;
        amountInput.placeholder = 'Max 2,000,000';
      }

      // Update active class on toggle buttons
      toggleBtns.forEach(btn => {
        if (btn.getAttribute('data-loan') === type) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
    }

    // Attach click handlers
    toggleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const loanType = btn.getAttribute('data-loan');
        setActiveLoan(loanType);
      });
    });

    // Initial check: set default (service)
    setActiveLoan('service');
  </script>
</body>
</html>


